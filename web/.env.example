# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe Dashboard → Webhooks → your endpoint

# Price IDs — one per plan (create in Stripe Dashboard → Products)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_SUPER_MONTHLY=price_...
STRIPE_PRICE_SHOGUN_MONTHLY=price_...

# Base URL (used in checkout success/cancel redirects)
NEXT_PUBLIC_SITE_URL=https://www.gradewithkatana.com

# Chrome Extension ID (for auth callback → extension messaging)
NEXT_PUBLIC_EXTENSION_ID=your_extension_id_here

# Admin dashboard gate — set to your email address
ADMIN_EMAIL=you@example.com

# Upstash Redis — rate limiting on /api/grade (20 req / 10 min per user)
# Create a free database at https://console.upstash.com
# Rate limiting is gracefully skipped if these are not set.
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
